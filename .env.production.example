# =============================================================================
# MCD-Agencia - PRODUCTION Environment Variables
# =============================================================================
# Copy this file to .env in the project root for docker-compose.prod.yml
#
# ⚠️  NEVER commit the .env file to version control
# ⚠️  Generate strong random values for all secrets
# =============================================================================

# -----------------------------------------------------------------------------
# Domain & URLs
# -----------------------------------------------------------------------------
DOMAIN=agenciamcd.mx
FRONTEND_URL=https://agenciamcd.mx
BACKEND_URL=https://agenciamcd.mx
NEXT_PUBLIC_API_URL=https://agenciamcd.mx/api/v1
NEXT_PUBLIC_SITE_URL=https://agenciamcd.mx
ALLOWED_HOSTS=agenciamcd.mx,www.agenciamcd.mx
CORS_ALLOWED_ORIGINS=https://agenciamcd.mx,https://www.agenciamcd.mx
CSRF_TRUSTED_ORIGINS=https://agenciamcd.mx,https://www.agenciamcd.mx

# -----------------------------------------------------------------------------
# Django Core
# -----------------------------------------------------------------------------
DJANGO_ENV=production
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=CHANGE-ME-generate-a-64-char-random-string

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DB_NAME=mcd_agencia
DB_USER=mcd_user
DB_PASSWORD=CHANGE-ME-strong-database-password

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_PASSWORD=CHANGE-ME-strong-redis-password

# -----------------------------------------------------------------------------
# Email (SendGrid)
# -----------------------------------------------------------------------------
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
DEFAULT_FROM_EMAIL=noreply@agenciamcd.mx

# -----------------------------------------------------------------------------
# AWS S3 / Object Storage (for media files)
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_STORAGE_BUCKET_NAME=mcd-agencia-media
AWS_S3_REGION_NAME=us-east-1
# For DigitalOcean Spaces or MinIO:
# AWS_S3_ENDPOINT_URL=https://nyc3.digitaloceanspaces.com

# -----------------------------------------------------------------------------
# Google OAuth
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# -----------------------------------------------------------------------------
# Payment Gateways
# -----------------------------------------------------------------------------
# Mercado Pago (LIVE credentials)
MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxx
MERCADOPAGO_PUBLIC_KEY=APP_USR-xxxxxxxxxxxx
MERCADOPAGO_WEBHOOK_SECRET=your-webhook-secret

# PayPal (LIVE credentials)
PAYPAL_CLIENT_ID=your-paypal-live-client-id
PAYPAL_CLIENT_SECRET=your-paypal-live-secret
PAYPAL_WEBHOOK_ID=your-paypal-webhook-id

# -----------------------------------------------------------------------------
# reCAPTCHA v3
# -----------------------------------------------------------------------------
RECAPTCHA_SITE_KEY=your-recaptcha-site-key
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-site-key

# -----------------------------------------------------------------------------
# Google Analytics / Maps (frontend)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your-maps-api-key

# -----------------------------------------------------------------------------
# WhatsApp Business API
# -----------------------------------------------------------------------------
WHATSAPP_PROVIDER=meta_cloud
WHATSAPP_PHONE_NUMBER=+52XXXXXXXXXX
WHATSAPP_API_TOKEN=your-whatsapp-token
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token

# -----------------------------------------------------------------------------
# Monitoring (Sentry)
# -----------------------------------------------------------------------------
SENTRY_DSN=https://xxxx@sentry.io/xxxx

# -----------------------------------------------------------------------------
# Performance Tuning
# -----------------------------------------------------------------------------
GUNICORN_WORKERS=4
CELERY_CONCURRENCY=2
