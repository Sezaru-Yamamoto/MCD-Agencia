# =============================================================================
# MCD-Agencia Backend Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values
# NEVER commit the .env file to version control
# =============================================================================

# -----------------------------------------------------------------------------
# Django Core Settings
# -----------------------------------------------------------------------------
DJANGO_ENV=development
DJANGO_SECRET_KEY=your-super-secret-key-change-in-production
DJANGO_DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# -----------------------------------------------------------------------------
# Database Configuration (PostgreSQL)
# -----------------------------------------------------------------------------
DB_NAME=mcd_agencia
DB_USER=postgres
DB_PASSWORD=your-database-password
DB_HOST=localhost
DB_PORT=5432

# For development with SQLite (optional)
USE_SQLITE=false

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# For development without Redis (optional)
USE_LOCAL_CACHE=false

# -----------------------------------------------------------------------------
# Celery Configuration
# -----------------------------------------------------------------------------
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_ALWAYS_EAGER=false

# -----------------------------------------------------------------------------
# Email Configuration
# -----------------------------------------------------------------------------
DEFAULT_FROM_EMAIL=noreply@agenciamcd.mx
SERVER_EMAIL=server@agenciamcd.mx

# SendGrid (Production)
SENDGRID_API_KEY=your-sendgrid-api-key

# -----------------------------------------------------------------------------
# AWS S3 / Object Storage
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_STORAGE_BUCKET_NAME=mcd-agencia-files
AWS_S3_REGION_NAME=us-east-1
# For S3-compatible services (DigitalOcean Spaces, MinIO)
AWS_S3_ENDPOINT_URL=

# -----------------------------------------------------------------------------
# Authentication - Google OAuth
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# -----------------------------------------------------------------------------
# Payment Gateways
# -----------------------------------------------------------------------------

# Mercado Pago
MERCADOPAGO_ACCESS_TOKEN=your-mercadopago-access-token
MERCADOPAGO_PUBLIC_KEY=your-mercadopago-public-key
MERCADOPAGO_WEBHOOK_SECRET=your-mercadopago-webhook-secret

# PayPal
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_MODE=sandbox
PAYPAL_WEBHOOK_ID=your-paypal-webhook-id

# -----------------------------------------------------------------------------
# WhatsApp Business API
# -----------------------------------------------------------------------------
WHATSAPP_PROVIDER=meta_cloud
WHATSAPP_PHONE_NUMBER=+521234567890
WHATSAPP_API_TOKEN=your-whatsapp-api-token
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# -----------------------------------------------------------------------------
# reCAPTCHA v3 Configuration
# -----------------------------------------------------------------------------
# Get keys from: https://www.google.com/recaptcha/admin
RECAPTCHA_SITE_KEY=your-recaptcha-site-key
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key
# Score threshold (0.0 = bot, 1.0 = human), default 0.5
RECAPTCHA_SCORE_THRESHOLD=0.5

# -----------------------------------------------------------------------------
# Security (Production)
# -----------------------------------------------------------------------------
CSRF_TRUSTED_ORIGINS=https://agenciamcd.mx,https://www.agenciamcd.mx

# -----------------------------------------------------------------------------
# Monitoring
# -----------------------------------------------------------------------------
SENTRY_DSN=your-sentry-dsn

# -----------------------------------------------------------------------------
# Development Tools
# -----------------------------------------------------------------------------
ENABLE_DEBUG_TOOLBAR=false
