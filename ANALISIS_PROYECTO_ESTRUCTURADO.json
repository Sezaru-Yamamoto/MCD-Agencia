        "refunded"
      ],
      "transiciones": {
        "draft": ["pending_payment", "cancelled"],
        "pending_payment": ["paid", "partially_paid", "cancelled"],
        "paid": ["in_production"],
        "partially_paid": ["paid", "in_production"],
        "in_production": ["ready"],
        "ready": ["completed"],
        "completed": ["refunded"],
        "cancelled": [],
        "refunded": []
      }
    },
    "Payment": {
      "estados": [
        "pending",
        "approved",
        "rejected",
        "in_process",
        "cancelled",
        "refunded"
      ],
      "transiciones": {
        "pending": ["approved", "rejected", "in_process", "cancelled"],
        "approved": ["refunded"],
        "rejected": [],
        "in_process": ["approved", "rejected"],
        "cancelled": [],
        "refunded": []
      }
    },
    "Lead": {
      "estados": ["new", "contacted", "qualified", "converted", "lost"],
      "transiciones": {
        "new": ["contacted"],
        "contacted": ["qualified", "lost"],
        "qualified": ["converted", "lost"],
        "converted": [],
        "lost": []
      }
    }
  },
  "campos_auditados_por_entidad": {
    "CatalogItem": [
      "name", "price", "description", "category", "is_active"
    ],
    "Order": [
      "status", "total", "address", "user"
    ],
    "Quote": [
      "status", "total", "pdf_file", "validity_date"
    ],
    "Payment": [
      "status", "amount", "provider_payment_id", "approved_at"
    ],
    "InventoryMovement": [
      "quantity", "stock_before", "stock_after", "reason"
    ],
    "User": [
      "email", "role", "is_active", "is_email_verified"
    ]
  },
  "notificaciones_por_evento": [
    {
      "evento": "Nueva solicitud de cotización",
      "tipo": "quote_request",
      "destinatarios": ["Sales", "Admin"],
      "trigger": "QuoteRequest.status = pending",
      "campos": ["request_number", "customer_name", "product_name", "urgency"]
    },
    {
      "evento": "Cotización enviada",
      "tipo": "quote_sent",
      "destinatarios": ["Customer"],
      "trigger": "Quote.status = sent",
      "campos": ["quote_number", "link_publico"]
    },
    {
      "evento": "Cotización aceptada",
      "tipo": "quote_accepted",
      "destinatarios": ["Sales", "Admin"],
      "trigger": "Quote.status = accepted",
      "campos": ["quote_number", "order_id"]
    },
    {
      "evento": "Pago recibido",
      "tipo": "payment_received",
      "destinatarios": ["Customer", "Admin"],
      "trigger": "Payment.status = approved",
      "campos": ["order_number", "amount", "provider"]
    },
    {
      "evento": "Pedido creado",
      "tipo": "order_created",
      "destinatarios": ["Customer"],
      "trigger": "Order.status = pending_payment",
      "campos": ["order_number", "total"]
    },
    {
      "evento": "Cambio de estado pedido",
      "tipo": "order_status",
      "destinatarios": ["Customer"],
      "trigger": "Order.status changed",
      "campos": ["order_number", "new_status"]
    },
    {
      "evento": "Stock bajo",
      "tipo": "low_stock_alert",
      "destinatarios": ["Admin"],
      "trigger": "stock ≤ stock_minimum",
      "campos": ["product_name", "current_stock", "minimum_threshold"]
    },
    {
      "evento": "Cotización expirando",
      "tipo": "quote_expiring",
      "destinatarios": ["Customer"],
      "trigger": "validity_date - 2 días",
      "campos": ["quote_number", "days_remaining"]
    }
  ]
}
