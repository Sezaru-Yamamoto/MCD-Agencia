# =============================================================================
# MCD-Agencia Frontend - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values
# NEVER commit the .env.local file to version control
# =============================================================================

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# -----------------------------------------------------------------------------
# Site Configuration
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Google Analytics 4
# -----------------------------------------------------------------------------
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX

# -----------------------------------------------------------------------------
# Microsoft Clarity (free heatmaps & session recordings)
# Get your project ID from: https://clarity.microsoft.com
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLARITY_ID=

# -----------------------------------------------------------------------------
# Facebook Pixel (optional - for Meta ads tracking)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_FB_PIXEL_ID=

# -----------------------------------------------------------------------------
# Google Maps
# -----------------------------------------------------------------------------
# Restrict this key in Google Cloud Console to specific domains
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your-google-maps-api-key

# -----------------------------------------------------------------------------
# reCAPTCHA v3 (Invisible)
# -----------------------------------------------------------------------------
# Get keys from: https://www.google.com/recaptcha/admin
# Use reCAPTCHA v3 for invisible protection
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-site-key

# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------
NODE_ENV=development
